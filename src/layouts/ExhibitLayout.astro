---
const { title, author, minutesRead, readingTime } = Astro.props.frontmatter ?? Astro.props;
const { headings } = Astro.props; 

// Font and Reset Imports
import 'normalize.css';
import '@fontsource-variable/montserrat';
import '@fontsource-variable/lora';
import '@fontsource-variable/noto-sans';

// Import your custom global styles (adjust path based on your folder structure)
import '../styles/global.css'; 

// Component Imports
import { Icon } from 'astro-icon/components';
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} - CSARCH2 Virtual Exhibit</title>
    </head>

    <body>
        <header class="header">
            <div class="header__titleblock">
                <strong>{title}</strong>
                <span class="header__subtitle">by {author}</span>
            </div>

            <a href="/" class="button">
                <Icon name="ic:round-arrow-back" />
                <span>Back to home</span>
            </a>
        </header>

        <main class="content">
            <div class="content__block">
                <div class="content__titlemeta">
                    <h1>{headings?.find(h => h.depth === 1)?.text || title}</h1>
                    <span>by {author} ・ {minutesRead || readingTime || '5 minute read'}</span>
                </div>

                <article class="article">
                    <slot />
                </article>
            </div>

            {headings && headings.length > 0 && (
                <nav class="toc">
                    <h2>Table of contents</h2>
                    <ul class="toc__list">
                        {headings.filter(h => h.depth > 1).map((heading) => (
                            <li class={`toc__item depth-${heading.depth}`}>
                                <a href={`#${heading.slug}`}>{heading.text}</a>
                            </li>
                        ))}
                    </ul>
                </nav>
            )}
        </main>

        <footer>CSARCH2 Virtual Exhibit &mdash; "Computer Architecture is Forever"</footer>
    </body>
</html>

<style>
    .article :global(h1:first-of-type) {
        display: none;
    }
</style>
