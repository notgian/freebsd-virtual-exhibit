---
const { title = "CSARCH2 Virtual Exhibit", author } = Astro.props.frontmatter ?? Astro.props;

// 1. Fetch all MDX files from the pages folder
// (Note: If you place this file directly in src/pages/index.astro instead of src/layouts/, change the path to './*.mdx')
const allExhibits = await Astro.glob('../pages/*.mdx');

// 2. Filter out the homepage (index.mdx) so it doesn't link to itself
const exhibits = allExhibits.filter(exhibit => !exhibit.file.includes('index.mdx'));

// Font and Reset Imports
import 'normalize.css';
import '@fontsource-variable/montserrat';
import '@fontsource-variable/lora';
import '@fontsource-variable/noto-sans';

// Import your custom global styles
import '../styles/global.css'; 

// Component Imports
import { Icon } from 'astro-icon/components';
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
    </head>

    <body>
        <header class="header">
            <strong>{title}</strong>
        </header>

        <main class="content">
            <nav class="toc">
                <h2>Exhibits</h2>
                <ul class="toc__list">
                    {exhibits.map((exhibit) => (
                        <li class="toc__item" style="margin-bottom: 1rem;">
                            <a href={exhibit.url} style="font-weight: 500;">
                                {exhibit.frontmatter.title || "Untitled Exhibit"}
                            </a>
                            {exhibit.frontmatter.author && (
                                <span style="display: block; font-size: 0.8rem; color: var(--muted);">
                                    by {exhibit.frontmatter.author}
                                </span>
                            )}
                        </li>
                    ))}
                </ul>
            </nav>
        </main>

        <footer>CSARCH2 Virtual Exhibit &mdash; "Computer Architecture is Forever"</footer>
    </body>
</html>
